      "text": "BatBase metadata (Django API + PostgreSQL)",
      "originalText": "BatBase metadata (Django API + PostgreSQL)",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
