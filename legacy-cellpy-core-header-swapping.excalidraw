      "width": 318.677734375,
      "height": 146.25,
      "roundness": null,
      "text": "RAW_PAIRS (10)   native <-> legacy\npotential            <-> voltage\ncycle_num            <-> cycle_index\nstep_num             <-> step_index\ndatapoint_num        <-> data_point\ncumulative_charge_capacity <-> charge_capacity\ncumulative_discharge_capacity <-> discharge_capacity\ntest_time, step_time, current,\ninternal_resistance  <-> (same name)",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "rect52",
      "originalText": "RAW_PAIRS (10)   native <-> legacy\npotential            <-> voltage\ncycle_num            <-> cycle_index\nstep_num             <-> step_index\ndatapoint_num        <-> data_point\ncumulative_charge_capacity <-> charge_capacity\ncumulative_discharge_capacity <-> discharge_capacity\ntest_time, step_time, current,\ninternal_resistance  <-> (same name)",
