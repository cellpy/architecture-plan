      "width": 480,
      "height": 88,
      "roundness": null,
      "text": "Native schema (config.py)\nSchema(raw=RawCols, cycle=CycleCols, step=StepCols)\nNATIVE names: potential, cycle_num, step_num,\ndatapoint_num, cumulative_charge_capacity, ...\ninjected into engines (schema-agnostic, thread-safe)",
