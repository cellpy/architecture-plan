      "x": 1010,
      "y": 1198,
      "width": 410,
      "height": 146,
      "roundness": null,
      "text": "CYCLE_PAIRS (23)   native -> legacy\nlast_test_time        -> test_time\ndatapoint_num_last    -> data_point\ntest_cumulated_*      -> cumulated_*\npotential_end_charge  -> end_voltage_charge\ntemperature_cell_mean -> temperature_mean\n+ 5 identity pass-throughs:\n  ir_charge, ir_discharge, charge_c_rate,\n  discharge_c_rate, normalized_cycle_index",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "rect56",
      "originalText": "CYCLE_PAIRS (23)   native -> legacy\nlast_test_time        -> test_time\ndatapoint_num_last    -> data_point\ntest_cumulated_*      -> cumulated_*\npotential_end_charge  -> end_voltage_charge\ntemperature_cell_mean -> temperature_mean\n+ 5 identity pass-throughs:\n  ir_charge, ir_discharge, charge_c_rate,\n  discharge_c_rate, normalized_cycle_index",
      "lineHeight": 1.25,
      "baseline": 142,
      "index": "au",
