      "id": "txt55",
      "type": "text",
      "x": 540,
      "y": 1198,
      "width": 420,
      "height": 162,
      "roundness": null,
      "text": "STEP TABLE\nSTEP_BASE_PAIRS (8) x STAT_SUFFIXES (7)\n  potential_mean  ->  voltage_avr   (mean->avr!)\n  charge_capacity_<stat> -> charge_<stat>\n  datapoint_num_<stat>   -> point_<stat>\n  internal_resistance_<stat> -> ir_<stat>\nSTEP_SCALAR_PAIRS (6):\n  cycle_num->cycle, step_num->step, step_type->type,\n  sub_step_num->sub_step, sub_step_type->sub_type,\n  c_rate->rate_avr",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "rect54",
      "originalText": "STEP TABLE\nSTEP_BASE_PAIRS (8) x STAT_SUFFIXES (7)\n  potential_mean  ->  voltage_avr   (mean->avr!)\n  charge_capacity_<stat> -> charge_<stat>\n  datapoint_num_<stat>   -> point_<stat>\n  internal_resistance_<stat> -> ir_<stat>\nSTEP_SCALAR_PAIRS (6):\n  cycle_num->cycle, step_num->step, step_type->type,\n  sub_step_num->sub_step, sub_step_type->sub_type,\n  c_rate->rate_avr",
      "lineHeight": 1.25,
      "baseline": 158,
      "index": "as",
      "autoResize": true
    },
